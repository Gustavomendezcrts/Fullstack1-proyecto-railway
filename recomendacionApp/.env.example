# ==============================
# Variables para Docker Compose
# Copia este archivo como .env y ajusta los valores
# ==============================

# MySQL container
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=bibliotecaduoc
MYSQL_HOST_PORT=3307
MYSQL_CONTAINER_PORT=3306

# App container
APP_HOST_PORT=8080

# Spring Boot app (en Docker)
DB_URL_DOCKER=jdbc:mysql://mysql:3306/bibliotecaduoc?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root

# Seguridad JWT (minimo 32 caracteres)
JWT_SECRET=change-me-jwt-secret-with-32-or-more-characters

